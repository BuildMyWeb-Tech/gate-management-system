{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "types": ["node"],

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": ["**/*.ts"],

  "exclude": [
    "node_modules",
    "dist"
  ]
}